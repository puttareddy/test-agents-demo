      "title": "JSONPlaceholder API",
      "description": "Free fake and reliable REST API for testing and prototyping. Powered by JSON Server + LowDB. All HTTP methods are supported. Note: POST/PUT/PATCH/DELETE requests do not persist data — responses simulate success but the server state is not actually mutated.\n",
      "version": "1.0.0",
      "contact": {
        "name": "typicode",
        "url": "https://jsonplaceholder.typicode.com"
      },
      "license": {
        "name": "MIT"
      }
    },
    "servers": [
      {
        "url": "https://jsonplaceholder.typicode.com",
        "description": "Production server"
      }
    ],
